@page "/"
@inject ReviewRepository Repo

<div class="counts">
    Всего отзывов: <b>@Repo.TotalCount</b>, сегодня 0, на модерации 0
</div>

<div class="searchrow">
    <input class="searchbox" placeholder="Поиск работодателя..." @bind="q" />
    <button class="searchbtn" @onclick="OnSearch">Найти</button>
</div>

<div class="pager">
    @for (var i = 1; i <= 10; i++)
    {
        <a class="page" href="javascript:void(0)">@i</a>
    }
    <span class="ellipsis">…</span>
    <a class="page" href="javascript:void(0)">841</a>
    <a class="page" href="javascript:void(0)">842</a>
    <a class="page" href="javascript:void(0)">≥+10</a>
</div>

<div class="reviewlist">
    @foreach (var r in Repo.GetLatest(20))
    {
        <div class="reviewitem">
            <div class="reviewtop">
                <div class="scoreline">
                    <span class="scoreplus">+@r.Score</span> –
                    <a class="companylink" href="/main/view/all/@r.Id">@r.Company</a>
                </div>
                <div class="dateline">@r.CreatedAt.LocalDateTime.ToString("dd MMMM yyyy, HH:mm:ss", new System.Globalization.CultureInfo("ru-RU"))</div>
            </div>

            <div class="reviewtext">
                @r.Text <a class="morelink" href="/main/view/all/@r.Id">…читать дальше</a>
            </div>

            <div class="metarow">
                Автор: <span class="metaval">@r.Author</span>
                <span class="sep">|</span>
                Категория: <a href="/categories">@r.Category</a>
                <span class="metarow-city">Город: <a href="/cities">@r.City</a></span>
            </div>
        </div>
    }
</div>

@code {
    private string q = "";

    private void OnSearch()
    {
        // Демонстрация — в реальном проекте фильтруйте репозиторий.
    }
}
