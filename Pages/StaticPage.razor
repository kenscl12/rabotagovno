@page "/{Slug}"

@code {
    [Parameter] public string Slug { get; set; } = "";

    private static readonly HashSet<string> Known = new(StringComparer.OrdinalIgnoreCase)
    {
        "news","about","contacts","employers","categories","cities","legal","idea"
    };
}

@if (!Known.Contains(Slug))
{
    <h1>Страница не найдена</h1>
    <p>Такой страницы нет.</p>
}
else
{
    @switch (Slug.ToLowerInvariant())
    {
        case "news":
            <h1>Новости</h1>
            <p>Здесь могли бы быть свежие новости о работодателях, изменениях в ТК РФ и интересные истории с работы.</p>
            <p class="muted">Пока что это примерная страница. Добавьте сюда свой контент или подключите ленту новостей.</p>
            break;

        case "about":
            <h1>О проекте</h1>
            <p>RabotaGovno.RU — неофициальный клон классического сайта с отзывами о работодателях.</p>
            <p>Цель проекта — дать возможность анонимно поделиться опытом работы в компаниях, предупредить других соискателей и собрать честные истории из реальной жизни.</p>
            <p class="muted">Текущий сайт — демо-версия. Вы можете доработать его под свои задачи.</p>
            break;

        case "contacts":
            <h1>Контакты</h1>
            <p>Если вы хотите предложить идею, сообщить об ошибке или предложить сотрудничество — напишите на условный адрес:</p>
            <p><b>Электронная почта:</b> support@example.com</p>
            <p class="muted">Замените этот блок на реальные контактные данные или форму обратной связи.</p>
            break;

        case "employers":
            <h1>Работодателям</h1>
            <p>Эта страница предназначена для представителей компаний.</p>
            <p>Вы можете следить за отзывами о своей компании, отвечать на них и использовать обратную связь для улучшения условий труда сотрудников.</p>
            <p class="muted">При желании сюда можно добавить форму запроса на официальные комментарии или модерацию отзывов.</p>
            break;

        case "categories":
            <h1>Категории</h1>
            <p>В будущем здесь можно сделать рубрикатор по отраслям: IT, продажи, логистика, маркетинг и другие.</p>
            <p class="muted">Сейчас это статическая заглушка. Реализуйте фильтрацию по категориям в базе, если она вам нужна.</p>
            break;

        case "cities":
            <h1>Города</h1>
            <p>Планируется список городов с количеством отзывов по каждому населенному пункту.</p>
            <p class="muted">Сделайте здесь фильтрацию отзывов по городу или страницу со списком популярных городов.</p>
            break;

        case "legal":
            <h1>Правовая информация</h1>
            <p>Здесь можно разместить пользовательское соглашение, политику конфиденциальности и правила публикации отзывов.</p>
            <p class="muted">Проверьте текст у юриста, если планируете запускать сайт в продакшн.</p>
            break;

        case "idea":
            <h1>Идея проекта</h1>
            <p>Идея проста: люди делятся честным мнением о своей работе, а соискатели делают выводы перед устройством в компанию.</p>
            <p>Чем больше объективных отзывов — тем прозрачнее рынок труда и меньше разочарований после выхода на новую работу.</p>
            break;

        default:
            <h1>@Slug</h1>
            <p class="muted">Статическая страница. Добавьте сюда свой контент.</p>
            break;
    }
}
